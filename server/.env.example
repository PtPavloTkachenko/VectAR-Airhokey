# VectAR Air-Hockey server — optional environment overrides.
# These are plain environment variables (the server does not auto-load this
# file): `export GOALIE_KP=4.2` in your shell, or
# `env GOALIE_KP=4.2 python -m game_bridge.main`.
# Everything has sane defaults; robot identity normally comes from
# ~/.anki_vector/sdk_config.ini written by the pairing wizard.

# --- Ports ---
#GAME_WS_PORT=8777          # lens (Spectacles) WebSocket
#GAME_WEB_PORT=8780         # web console (pairing wizard + dashboard); 0 = off

# --- Robot identity overrides (rarely needed) ---
#VECTOR_SERIAL=00e20145     # pick a robot when sdk_config.ini has several
#VECTOR_IP=192.168.1.42     # comma-separated candidates if DHCP bounces
#VECTOR_NAME=Vector-A1B2

# --- Pairing ---
#WIREPOD_URL=http://escapepod.local:8080   # wizard default wire-pod address

# --- In-game Gemini voice agent (optional; lens needs an RSG token too) ---
#VECTAR_CHAT=1

# --- Goalie tuning (see docs/SERVER.md) ---
#GOALIE_KP=3.8
#GOALIE_MAX_WHEEL=218
#GOALIE_SHOWMAN=1
